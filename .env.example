# AgentForge side-car local runtime defaults
# Localhost-only by default for safety.
AGENTFORGE_BIND_HOST=127.0.0.1

# Service ports
AGENTFORGE_AGENTD_PORT=8410
AGENTFORGE_GMAILD_PORT=8411
AGENTFORGE_EXCHANGED_PORT=8412
AGENTFORGE_RSSD_PORT=8413

# Comma-separated side-car connectors to start with `agentctl up`
AGENTFORGE_ENABLED_CONNECTORS=gmaild,exchanged

# Local process state directory used by agentctl up/down
AGENTFORGE_STATE_DIR=.agentforge/sidecar

# Optional command overrides (defaults to python -m http.server <port> --bind <host>)
# AGENTFORGE_AGENTD_CMD=
# AGENTFORGE_GMAILD_CMD=
# AGENTFORGE_EXCHANGED_CMD=
# AGENTFORGE_RSSD_CMD=
